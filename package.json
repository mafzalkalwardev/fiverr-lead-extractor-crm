    "@types/sentiment": "^5.0.4",
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.5"
  }
