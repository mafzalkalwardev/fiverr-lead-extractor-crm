{
  "name": "fiverr-lead-extractor-crm",
  "version": "2.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "mongo:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-mongo.ps1",
    "dev": "next dev --turbopack -p 3000",
    "dev:webpack": "next dev",
    "dev:fresh": "npm run clean && next dev --turbopack -p 3000",
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}});console.log('Cleaned .next cache')\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx src/worker/index.ts",
    "scraper:py": "node scripts/run-python-scraper.js",
    "setup:browser:py": "node scripts/run-python-scraper.js --setup",
    "free:browser": "powershell -ExecutionPolicy Bypass -File scripts/free-browser-profile.ps1",
    "free:browser:kill": "powershell -ExecutionPolicy Bypass -File scripts/free-browser-profile.ps1 -KillProcesses",
    "free:port": "powershell -ExecutionPolicy Bypass -File scripts/free-port.ps1",
    "open:login": "powershell -ExecutionPolicy Bypass -File scripts/open-login.ps1",
    "client:repair": "npm run mongo:local && npm run free:port && npm run free:browser:kill && npm run clean && concurrently -n web,scraper -c blue,green \"npm run dev\" \"npm run scraper:py\"",
    "scraper:py:safe": "npm run free:browser && npm run scraper:py",
    "dev:all": "npm run mongo:local && concurrently \"npm run dev\" \"npm run scraper:py\"",
    "client:start": "npm run mongo:local && npm run free:port && concurrently -n web,scraper -c blue,green \"npm run dev\" \"npm run scraper:py\"",
    "client:start:fast": "npm run mongo:local && npm run free:port && concurrently -n web,scraper -c blue,green \"npm run dev\" \"npm run scraper:py\"",
    "client:prod": "npm run mongo:local && concurrently -n web,scraper -c blue,green \"npm run build && npm start\" \"npm run scraper:py\"",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "repair:leads": "python scripts/repair-lead-reviewers.py",
    "electron": "electron .",
    "electron:dev": "electron .",
    "electron:app": "electron .",
    "electron:build": "npm run build && electron .",
    "migrate:jobs": "tsx scripts/migrate-jobs-schema.ts",
    "setup:browser": "tsx scripts/setup-browser.ts",
    "test:manual": "tsx scripts/run-manual-job.ts",
    "test:e2e": "tsx scripts/test-e2e.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.469.0",
    "mongoose": "^8.9.3",
    "next": "^15.1.3",
    "playwright": "^1.49.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "sentiment": "^5.0.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/sentiment": "^5.0.4",
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.5"
  }
}
