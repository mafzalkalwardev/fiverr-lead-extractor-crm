{
  "name": "fiverr-lead-extractor-crm",
  "version": "2.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}});console.log('Cleaned .next cache')\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx src/worker/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"npm run worker\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron .",
    "purge:leads": "tsx scripts/purge-fake-leads.ts",
    "migrate:jobs": "tsx scripts/migrate-jobs-schema.ts",
    "mark:demo-jobs": "tsx scripts/mark-legacy-demo-jobs.ts",
    "setup:browser": "tsx scripts/setup-browser.ts",
    "test:manual": "tsx scripts/run-manual-job.ts",
    "test:e2e": "tsx scripts/test-e2e.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.469.0",
    "mongoose": "^8.9.3",
    "next": "^15.1.3",
    "playwright": "^1.49.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "sentiment": "^5.0.2",
    "tailwind-merge": "^2.6.0",
