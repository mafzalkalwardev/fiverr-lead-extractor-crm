# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLIENT_MODE=false
SCRAPER_ENGINE=python
NODE_ENV=development

# MongoDB
# Startup uses bundled portable MongoDB and rewrites this to 27018 if 27017 is busy.
MONGODB_URI=mongodb://127.0.0.1:27017/fiverr-lead-extractor-crm

# Redis 5+ (legacy BullMQ support; Python scraper uses MongoDB polling)
REDIS_URL=redis://127.0.0.1:6380

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Admin seed (npm run seed:admin)
ADMIN_EMAIL=admin@ftsolutions.local
ADMIN_PASSWORD=Admin@FT2024
ADMIN_NAME=FT Solutions Admin

# Scraper (UI + legacy Node worker)
SCRAPER_MODE=playwright
PLAYWRIGHT_HEADLESS=false
KEEP_BROWSER_PROFILE=true
# Node legacy worker only — Python uses bundled Chromium by default
PLAYWRIGHT_CHANNEL=chrome

# Python scraper (npm run scraper:py) — polls MongoDB, Redis optional
# PYTHON_USE_SYSTEM_CHROME=true
# PYTHON_PLAYWRIGHT_CHANNEL=chrome
# PYTHON_BROWSER_PROFILE=browser-profile
PYTHON_SCRAPER_POLL_SEC=1.5
BLOCK_HEAVY_RESOURCES=true
DISCOVERY_SCROLL_LOOPS=4
DISCOVERY_PAGE_WAIT_SEC=1.5
# 0 = scrape all Fiverr search pages until the last page (safety cap: MAX_SEARCH_PAGES_SAFETY)
MAX_PAGES_LIMIT=0
PYTHON_VERIFICATION_POLL_SEC=2
PYTHON_VERIFICATION_TIMEOUT_SEC=600
PYTHON_AUTO_VERIFICATION_MAX_ATTEMPTS=8
PYTHON_AUTO_VERIFICATION_RECHECK_SEC=2
PYTHON_AUTO_VERIFICATION_RETRY_INTERVAL_SEC=35
REVIEW_MAX_PAGES=50
ALLOW_OS_MOUSE_AUTOMATION=false
FOCUS_BROWSER_ON_VERIFICATION=true
BROWSER_WINDOW_WIDTH=1440
BROWSER_WINDOW_HEIGHT=900
BROWSER_WINDOW_X=20
BROWSER_WINDOW_Y=20

# Limits
DEFAULT_DELAY_SECONDS=3
# 0 = no cap on gigs per job (all pages, all gigs)
MAX_GIGS_LIMIT=0
MAX_REVIEWS_PER_GIG_LIMIT=1500
DEFAULT_DELAY_SECONDS=1
MAX_TOTAL_LEADS_LIMIT=0
MAX_RETRIES=3
MAX_FAILED_URL_RETRY_PASSES=1

# Set true to allow public /register (disabled by default)
ALLOW_PUBLIC_REGISTER=false
